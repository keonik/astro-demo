---
import BaseLayout from "../layouts/BaseLayout.astro";
import ParallaxScene from "../components/ParallaxScene.astro";
import { getCollection } from "astro:content";
import { formatDate, sortByDate } from "../lib/utils";

const posts = sortByDate(
  (await getCollection("blog")).filter((p) => !p.data.draft)
).slice(0, 3);

const projects = sortByDate(
  (await getCollection("projects")).filter((p) => !p.data.draft)
).slice(0, 3);
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    name: "John Fay",
    url: "https://keonik.dev",
    jobTitle: "Staff Software Engineer",
    sameAs: [
      "https://github.com/keonik",
      "https://www.linkedin.com/in/johnkfay/"
    ],
    image: "https://keonik.dev/images/avatar.webp",
  })} />
  <ParallaxScene />

  <div class="relative z-10 max-w-3xl mx-auto px-6 py-20">
    <!-- Content panel with solid background for readability -->
    <div class="bg-white dark:bg-gray-950 md:dark:bg-gray-950/90 md:backdrop-blur-sm md:rounded-2xl md:px-10 md:py-12 md:-mx-4 md:shadow-sm md:dark:shadow-none md:border md:border-gray-200/50 md:dark:border-gray-800/50">
    <!-- Hero -->
    <section class="animate-fade-in-up">
      <div class="flex flex-col-reverse sm:flex-row items-start sm:items-center gap-6 sm:gap-10">
        <div class="flex-1">
          <p class="text-sm font-medium text-accent dark:text-accent-dark mb-2">Hey, I'm</p>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
            John Fay
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl leading-relaxed">
            Staff Software Engineer building full-stack products and AI-powered systems.
            Navy veteran, open-source contributor, and forever learner.
          </p>
          <div class="flex gap-4 mt-6">
            <a href="/work" class="text-sm font-medium text-accent dark:text-accent-dark hover:underline">
              View my work &rarr;
            </a>
            <a href="/blog" class="text-sm font-medium text-gray-700 hover:text-gray-900 dark:hover:text-gray-300 hover:underline">
              Read my blog &rarr;
            </a>
          </div>
        </div>
        <div class="avatar-float shrink-0">
          <img
            src="/images/avatar.webp"
            alt="John Fay"
            width="160"
            height="160"
            class="w-28 h-28 sm:w-40 sm:h-40 rounded-2xl object-cover shadow-lg ring-4 ring-white/50 dark:ring-gray-700/50"
          />
        </div>
      </div>
    </section>

    <!-- Recent Posts -->
    <section class="mt-20 animate-fade-in-up animate-delay-100">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-semibold">Recent Posts</h2>
        <a href="/blog" class="text-sm text-gray-700 hover:text-gray-900 dark:hover:text-gray-300 transition-colors">
          View all &rarr;
        </a>
      </div>
      <div class="space-y-6">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="block group">
            <article class="interactive-card p-4 -mx-4 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-900/50 transition-colors">
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-medium group-hover:text-accent dark:group-hover:text-accent-dark transition-colors">
                  {post.data.title}
                </h3>
                <time class="text-sm text-gray-400 shrink-0" datetime={post.data.date.toISOString()}>
                  {formatDate(post.data.date)}
                </time>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 line-clamp-1">
                {post.data.summary}
              </p>
            </article>
          </a>
        ))}
      </div>
    </section>

    <!-- Projects -->
    <section class="mt-20 animate-fade-in-up animate-delay-200">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-semibold">Projects</h2>
        <a href="/projects" class="text-sm text-gray-700 hover:text-gray-900 dark:hover:text-gray-300 transition-colors">
          View all &rarr;
        </a>
      </div>
      <div class="grid gap-4">
        {projects.map((project) => (
          <div class="interactive-card p-4 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-all duration-200">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-medium">{project.data.title}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{project.data.summary}</p>
              </div>
              <div class="flex gap-2 shrink-0">
                {project.data.repoUrl && (
                  <a href={project.data.repoUrl} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Source code">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  </a>
                )}
                {project.data.demoUrl && (
                  <a href={project.data.demoUrl} target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" aria-label="Demo">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                )}
              </div>
            </div>
            <div class="flex gap-2 mt-3 flex-wrap">
              {project.data.tags.slice(0, 4).map((tag) => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                  {tag}
                </span>
              ))}
              {project.data.tags.length > 4 && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">
                  +{project.data.tags.length - 4}
                </span>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
    </div><!-- end content panel -->
  </div>


</BaseLayout>
